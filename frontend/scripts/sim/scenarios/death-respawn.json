{
  "server": "sim-1",
  "url": "http://127.0.0.1:3000",
  "interval": 500,
  "players": [
    { "userid": "KU_alice", "name": "Alice", "admin": true }
  ],
  "steps": [
    { "note": "Alice dies — flow 'death → respawn' should fire" },
    { "emit": "player_death", "data": { "userid": "KU_alice", "cause": "spider" } },
    { "wait": 600 },
    { "expectCommand": { "type": "respawn", "match": { "userid": "KU_alice" } } },

    { "note": "A non-triggering event must produce no respawn" },
    { "emit": "player_craft", "data": { "userid": "KU_alice", "prefab": "axe" } },
    { "wait": 400 }
  ]
}
