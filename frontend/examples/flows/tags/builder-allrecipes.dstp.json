{
  "name": "!builder — desbloqueia todas as receitas (call_component builder, admin)",
  "nodes": [
    { "id": "trg", "type": "trigger", "position": { "x": 0, "y": 0 }, "data": { "event_type": "chat_message", "alias": "chat" } },
    { "id": "iscmd", "type": "condition", "position": { "x": 300, "y": 0 }, "data": { "field": "{{chat.message}}", "operator": "starts_with", "value": "!builder" } },
    { "id": "who", "type": "get_player", "position": { "x": 600, "y": 0 }, "data": { "params": { "userid": "{{chat.userid}}" }, "alias": "player" } },
    { "id": "isadmin", "type": "condition", "position": { "x": 900, "y": 0 }, "data": { "field": "{{player.admin}}", "operator": "equals", "value": "true" } },
    { "id": "give", "type": "call_component", "position": { "x": 1200, "y": 0 }, "data": { "params": { "userid": "{{chat.userid}}", "component": "builder", "method": "GiveAllRecipes", "args": "[]" } } },
    { "id": "notify", "type": "action", "position": { "x": 1500, "y": 0 }, "data": { "action_type": "ui_notification", "params": { "userid": "{{chat.userid}}", "text": "Todas as receitas desbloqueadas", "duration": "3" } } }
  ],
  "edges": [
    { "id": "e_trg_iscmd", "source": "trg", "target": "iscmd" },
    { "id": "e_iscmd_who", "source": "iscmd", "target": "who", "sourceHandle": "true" },
    { "id": "e_who_admin", "source": "who", "target": "isadmin" },
    { "id": "e_admin_give", "source": "isadmin", "target": "give", "sourceHandle": "true" },
    { "id": "e_give_notify", "source": "give", "target": "notify" }
  ]
}
