{
  "name": "AI Agent Test (chat -> announce)",
  "nodes": [
    { "id": "trg", "type": "trigger", "position": { "x": 0, "y": 0 }, "data": { "event_type": "chat_message" } },
    {
      "id": "ai",
      "type": "ai_agent",
      "position": { "x": 0, "y": 200 },
      "data": {
        "provider": "openai",
        "model": "gpt-4o-mini",
        "api_key": "{{environment.prod.OPENAI_KEY}}",
        "system": "You are a friendly Don't Starve Together server assistant. When a player chats, respond with a short in-game announcement by calling the announce tool. Keep it under ~80 chars, plain text, no emojis.",
