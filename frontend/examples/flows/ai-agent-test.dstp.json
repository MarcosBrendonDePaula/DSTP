    { "id": "ann", "type": "action", "position": { "x": 360, "y": 200 }, "data": { "action_type": "announce", "params": { "message": "" } } }
  ],
  "edges": [
    { "id": "e_trg_ai", "source": "trg", "target": "ai" },
    { "id": "e_ann_ai", "source": "ann", "target": "ai", "targetHandle": "tools" }
  ]
