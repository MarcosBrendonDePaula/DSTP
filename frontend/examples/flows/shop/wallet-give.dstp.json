{
  "name": "Carteira — !dar credita +100 e atualiza o painel ao vivo (admin)",
  "nodes": [
    { "id": "trg", "type": "trigger", "position": { "x": 0, "y": 0 }, "data": { "event_type": "chat_message", "alias": "chat" } },
    { "id": "isdar", "type": "condition", "position": { "x": 300, "y": 0 }, "data": { "field": "{{chat.message}}", "operator": "starts_with", "value": "!dar" } },
    { "id": "who", "type": "get_player", "position": { "x": 600, "y": 0 }, "data": { "params": { "userid": "{{chat.userid}}" }, "alias": "player" } },
    { "id": "isadmin", "type": "condition", "position": { "x": 900, "y": 0 }, "data": { "field": "{{player.admin}}", "operator": "equals", "value": "true" } },
    { "id": "read", "type": "memory", "position": { "x": 1200, "y": 0 }, "data": { "action": "read", "params": { "flow": "shop", "key": "coins:{{chat.userid}}" }, "alias": "bal" } },
    { "id": "credit", "type": "transform", "position": { "x": 1500, "y": 0 }, "data": { "params": { "value": "{{bal.value}}", "operation": "add", "operand": "100" }, "alias": "newbal" } },
    { "id": "write", "type": "memory", "position": { "x": 1800, "y": 0 }, "data": { "action": "write", "params": { "flow": "shop", "key": "coins:{{chat.userid}}", "value": "{{newbal.value}}" } } },
    { "id": "update", "type": "action", "position": { "x": 2100, "y": 0 }, "data": { "action_type": "ui_set", "params": { "userid": "{{chat.userid}}", "id": "wallet", "node": "saldo_txt", "text": "{{newbal.value}}" } } }
  ],
  "edges": [
    { "id": "e_trg_isdar", "source": "trg", "target": "isdar" },
    { "id": "e_dar_who", "source": "isdar", "target": "who", "sourceHandle": "true" },
    { "id": "e_who_admin", "source": "who", "target": "isadmin" },
    { "id": "e_admin_read", "source": "isadmin", "target": "read", "sourceHandle": "true" },
    { "id": "e_read_credit", "source": "read", "target": "credit" },
    { "id": "e_credit_write", "source": "credit", "target": "write" },
    { "id": "e_write_update", "source": "write", "target": "update" }
  ]
}
