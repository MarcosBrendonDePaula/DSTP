        },
        "alias": "p"
      }
    },
    {
      "id": "pm",
      "type": "action",
      "position": {
        "x": 900,
        "y": 0
      },
      "data": {
        "action_type": "private_message",
        "params": {
          "userid": "{{cmd.userid}}",
