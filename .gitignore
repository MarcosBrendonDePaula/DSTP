# Data (per-server SQLite DBs). Anchored with a leading slash so it only matches
# the runtime data dirs at the repo root / frontend root — NOT nested code folders
# like app/shared/automation/nodes/data/ (a node category).
/data/
/frontend/data/

# Dependencies
node_modules/

# Local Claude Code config
.claude/

# Build artifacts
*.bun-build
*.exe
dist/

# Local relay dev binary (built from the dstp-relay repo)
relay-dev/
.audit/
.gitmsg
