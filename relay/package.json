{
  "name": "dstp-relay",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "bun run relay.ts",
    "build": "bun build relay.ts --compile --outfile=dist/dstp-relay",
    "build:win": "bun build relay.ts --compile --target=bun-windows-x64 --outfile=dist/dstp-relay.exe",
    "build:linux": "bun build relay.ts --compile --target=bun-linux-x64 --outfile=dist/dstp-relay-linux",
    "build:mac": "bun build relay.ts --compile --target=bun-darwin-arm64 --outfile=dist/dstp-relay-mac",
    "build:all": "bun run build:win && bun run build:linux && bun run build:mac"
  }
}
